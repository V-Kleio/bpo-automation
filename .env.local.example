# Copy to .env.local and fill in only the keys you have access to.

# --- Layer 1: HubSpot read-only (pull contacts into the leads table) ---
# Required scope: crm.objects.contacts.read
# Pulls from https://api.hubapi.com/crm/v3/objects/contacts and groups
# contacts by their `company` property into Company + Stakeholder records.
# Leave blank to skip HubSpot entirely — no errors, the Sync button hides.
HUBSPOT_PRIVATE_APP_TOKEN=

# --- Layer 2: AI reasoning provider (real AI analysis + chat) ---
# Pick ONE provider via AI_PROVIDER. With nothing configured, Layer 2 is
# hard-disabled: the analyze and chat UI show an "AI provider not configured"
# error. Everything here is also editable live from the Settings page.
#
#   AI_PROVIDER options:
#     auto        (default) Anthropic if its creds are set, else the
#                 OpenAI-compatible endpoint below
#     anthropic   force Anthropic (uses the ANTHROPIC_* keys)
#     groq        Groq          (free; console.groq.com)
#     openrouter  OpenRouter    (has free models; openrouter.ai/keys)
#     gemini      Google Gemini (free; aistudio.google.com/apikey)
#     ollama      local Ollama  (no key needed)
#     custom      any other OpenAI-compatible endpoint (set AI_OPENAI_BASE_URL)
AI_PROVIDER=

# -- Anthropic (used when AI_PROVIDER is anthropic, or auto with these set) --
# Two supported auth paths — set ONE.
#  (a) First-party API key.  Standard Anthropic API access.
ANTHROPIC_API_KEY=
#  (b) OAuth bearer via a gateway (e.g. Claude Max).
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
#
# Web search uses Anthropic's server-side `web_search_20250305` tool, a
# first-party-API feature (not available on other providers). The Claude Max
# OAuth gateway may reject it, so it auto-disables under ANTHROPIC_AUTH_TOKEN.
#   ANTHROPIC_ENABLE_WEB_SEARCH=1   force-on (only if your gateway supports it)
#   ANTHROPIC_ENABLE_WEB_SEARCH=0   force-off
#   (unset)                         on iff ANTHROPIC_API_KEY is set
ANTHROPIC_ENABLE_WEB_SEARCH=
# Analysis: heavy reasoning per company. Opus 4.7 is the most capable;
# override to claude-sonnet-4-6 to halve cost when needed.
CLAUDE_MODEL_ANALYZE=claude-opus-4-7
# Chat: short-form, streaming. Haiku 4.5 has the fastest time-to-first-token.
CLAUDE_MODEL_CHAT=claude-haiku-4-5

# -- OpenAI-compatible (Groq / OpenRouter / Gemini / Ollama / Custom) --
# Presets fill in the base URL for you; only set AI_OPENAI_BASE_URL for
# AI_PROVIDER=custom. Leave the key blank for a local Ollama endpoint.
AI_OPENAI_API_KEY=
AI_OPENAI_BASE_URL=
# Models depend on the provider, e.g.
#   Groq:       llama-3.3-70b-versatile / llama-3.1-8b-instant
#   OpenRouter: meta-llama/llama-3.3-70b-instruct / google/gemini-2.0-flash-exp:free
#   Gemini:     gemini-2.0-flash
#   Ollama:     llama3.1:8b
AI_OPENAI_MODEL_ANALYZE=
AI_OPENAI_MODEL_CHAT=
# How structured analysis is requested: auto (tools, then JSON-mode fallback),
# tools (force function-calling), or json_object (force JSON-mode).
AI_OPENAI_STRUCTURED_MODE=
# Output token cap. Free models often cap low; keep ≤ the model's limit.
AI_OPENAI_MAX_TOKENS=4096

# --- Layer 3: LinkedIn automation ---
# Provider precedence: unipile > mcp > playwright
# Set at most one of these — the rest are ignored.

# 3rd-party REST provider (Unipile, etc.). Leave blank to skip.
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=

# LinkedIn MCP server URL (optional plug-in point). Leave blank to skip.
LINKEDIN_MCP_URL=

# Playwright headless browser fallback (free, runs locally).
# Set to "1" to enable. You will then "Connect LinkedIn" once from the
# Campaigns page; the session is saved to LINKEDIN_SESSION_PATH and reused.
# Requires `npx playwright install chromium`.
ENABLE_PLAYWRIGHT_LINKEDIN=0
LINKEDIN_SESSION_PATH=.data/linkedin/session.json
# Default: headless. Set to "false" or "0" to run actual sends in a
# visible browser window. Visible mode is much friendlier to LinkedIn's
# anti-automation heuristics (the authwall) but you'll see a window pop
# up for each send.
LINKEDIN_PLAYWRIGHT_HEADLESS=true

# Anti-block controls (apply to any real provider).
LINKEDIN_DAILY_CAP=25
LINKEDIN_MIN_DELAY_MS=180000
LINKEDIN_MAX_DELAY_MS=600000

# --- Layer 1: MySQL database (local Docker container) ---
# Start the container:
#   docker run --name bpo-mysql \
#     -e MYSQL_ROOT_PASSWORD=mypassword \
#     -e MYSQL_DATABASE=bpo_db \
#     -p 3306:3306 -d mysql:8
# The sync button appears on the Leads page when DB_HOST + DB_USER + DB_NAME
# are all set. The route auto-discovers the first table named leads, contacts,
# companies, prospects, or targets; falls back to the first table in the DB.
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bpo_db
DB_USER=root
DB_PASSWORD=
